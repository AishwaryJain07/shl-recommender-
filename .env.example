# SHL Conversational Recommender — environment configuration.
# Copy to `.env` for local development. In production, set these as host env
# vars (never commit real secrets — see BUILD_SPEC §12).

# --- Data source (BUILD_SPEC §2) ---
CATALOG_URL=https://tcp-us-prod-rnd.shl.com/voiceRater/shl-ai-hiring/shl_product_catalog.json
RAW_CATALOG_PATH=data/shl_catalog_raw.json
NORMALIZED_CATALOG_PATH=data/catalog_normalized.json

# --- Eval assets (BUILD_SPEC §9) ---
TRACES_DIR=eval/traces
TRACES_PARSED_PATH=eval/traces_parsed.json
EVAL_BASE_URL=http://127.0.0.1:8000

# --- HTTP (catalog download) ---
HTTP_TIMEOUT_S=60

# --- Retrieval (BUILD_SPEC §5) ---
RETRIEVAL_TOP_K=30

# --- LLM provider: Gemini via its OpenAI-compatible endpoint (BUILD_SPEC §6) ---
# REQUIRED to serve real recommendations. Free key: https://aistudio.google.com/apikey
# Gemini 2.5 Flash free tier = 15 req/min, 1M tokens/min (far more headroom than
# Groq's free tier, which throttled us on tokens-per-minute and tokens-per-day).
GEMINI_API_KEY=
LLM_BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai/
LLM_MODEL=gemini-2.5-flash
# Name of the env var holding the API key (lets you swap providers cleanly).
# Falls back to GROQ_API_KEY if the named var is empty.
LLM_API_KEY_ENV=GEMINI_API_KEY
LLM_TEMPERATURE=0
LLM_TIMEOUT_S=30
LLM_MAX_RETRIES=2
LLM_MAX_TOKENS=1200
LLM_BACKOFF_CAP_S=12
# To use Groq instead: set GROQ_API_KEY, LLM_API_KEY_ENV=GROQ_API_KEY,
# LLM_BASE_URL=https://api.groq.com/openai/v1, LLM_MODEL=llama-3.1-8b-instant

# --- Agent policy (BUILD_SPEC §6.2, §8) ---
MAX_CLARIFY_TURNS=2
MAX_RECOMMENDATIONS=10
FALLBACK_RECOMMEND_N=3
